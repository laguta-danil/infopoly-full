# App (start:prod and dev both use NODE_ENV=development for presentation)
NODE_ENV=development
PORT=3010
API_PREFIX=api

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infopoly?schema=public

# JWT
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Auth cookie (Bearer token is primary for SPA; cookie optional)
COOKIE_NAME=access_token
COOKIE_SAME_SITE=lax

# Security
BCRYPT_ROUNDS=10

# Swagger
SWAGGER_PATH=api/docs

# CORS — comma-separated origins (localhost + Cloudflare tunnel web hostname)
CORS_ORIGIN=http://localhost:3011,https://todo.skoldrum.online

# Throttler (per-IP rate limiting on /auth)
THROTTLE_TTL=60
THROTTLE_LIMIT=5
